// Touchscreen Buttons — up to 5 pages of 6 tiles on the side screen.
import { Theme } from "../theme.slint";
import { Buttons, DashButton, DeviceCaps } from "../models.slint";
import { Card, PrimaryButton, Segmented, ToggleSwitch, Swatch, SectionLabel, Mono } from "../widgets.slint";
import { DeviceScreen } from "../components/device-screen.slint";

// Per-button field picker. `value` is a PURE binding to the selected tile's
// field name, so switching tiles always shows that tile's value (blank when
// none) — unlike std-widgets ComboBox, whose current-index binding breaks the
// moment the user picks something, making it look "global".
component FieldDropdown inherits Rectangle {
    in property <string> value;          // current field name ("" = none)
    in property <[string]> options;
    callback picked(string);
    height: 36px;
    border-radius: 8px;
    border-width: 1px;
    border-color: ta.has-hover ? Theme.line2 : Theme.line;
    background: Theme.panel2;
    HorizontalLayout {
        padding-left: 12px; padding-right: 10px;
        Text {
            text: root.value == "" ? "— none —" : root.value;
            color: root.value == "" ? Theme.text3 : Theme.text;
            font-family: Theme.body-font; font-size: 14px;
            vertical-alignment: center; horizontal-stretch: 1;
        }
        Text { text: "▾"; color: Theme.text3; font-size: 11px; vertical-alignment: center; }
    }
    ta := TouchArea { clicked => { pop.show(); } }
    pop := PopupWindow {
        x: 0; y: parent.height + 4px;
        width: root.width;
        height: 220px;
        Rectangle {
            background: Theme.elev;
            border-radius: 8px;
            border-width: 1px;
            border-color: Theme.line2;
            Flickable {
                viewport-height: col.preferred-height;
                col := VerticalLayout {
                    padding: 4px;
                    for o[i] in root.options: Rectangle {
                        height: 28px;
                        border-radius: 5px;
                        background: o == root.value ? Theme.accent-dim : (opta.has-hover ? Theme.panel : transparent);
                        HorizontalLayout {
                            padding-left: 8px;
                            Text {
                                text: o == "" ? "— none —" : o;
                                color: o == root.value ? Theme.accent : Theme.text2;
                                font-family: Theme.body-font; font-size: 13px; vertical-alignment: center;
                            }
                        }
                        opta := TouchArea { clicked => { root.picked(o); pop.close(); } }
                    }
                }
            }
        }
    }
}

export component ButtonsScreen inherits Rectangle {
    property <[DashButton]> cur-page: Buttons.tiles;
    property <DashButton> cur: cur-page[Buttons.sel];
    property <[color]> palette: [#00E5A0, #FFB300, #FF3B30, #2E9DFF, #D500F9, #E8EAED];

    // Typing into a TextInput severs its `text` binding, so the LABEL field won't
    // follow when a different tile is selected. Re-seed it whenever the selected
    // tile (page + index) changes.
    property <int> sel-key: Buttons.page * 1000 + Buttons.sel;
    changed sel-key => { ti.text = root.cur.label; }

    VerticalLayout {
        padding: 24px;
        spacing: 16px;
        HorizontalLayout {
            VerticalLayout {
                alignment: center;
                spacing: 3px;
                Text { text: "Touchscreen Buttons"; color: Theme.text; font-family: Theme.display-font; font-size: 24px; font-weight: 700; }
                Text { text: "Side screen · " + DeviceCaps.side-res + " · " + Buttons.page-count + " pages · 6 tiles each"; color: Theme.text3; font-size: 13px; }
            }
            Rectangle { }
            VerticalLayout { alignment: center;
                if Buttons.save-status != "": Text {
                    text: Buttons.save-status;
                    color: (Buttons.save-status == "Not connected" || Buttons.save-status == "Device rejected — update firmware") ? Theme.red : Theme.green;
                    font-size: 12px; horizontal-alignment: right;
                }
            }
            PrimaryButton { text: "SAVE TO DEVICE"; clicked => { Buttons.save(); } }
        }
        // page tabs (with add / delete)
        HorizontalLayout {
            spacing: 16px;
            for i in Buttons.page-list: HorizontalLayout {
                spacing: 4px;
                TouchArea {
                    clicked => { Buttons.select-page(i); }
                    VerticalLayout {
                        spacing: 6px;
                        Text { text: "Page " + (i + 1); color: i == Buttons.page ? Theme.text : Theme.text3; font-family: Theme.display-font; font-size: 15px; font-weight: 600; }
                        Rectangle { height: 2px; background: i == Buttons.page ? Theme.accent : transparent; }
                    }
                }
                if Buttons.page-count > 1: delx := TouchArea {
                    width: 16px;
                    Text { text: "✕"; color: delx.has-hover ? Theme.red : Theme.text3; font-size: 11px; vertical-alignment: center; horizontal-alignment: center; }
                    clicked => { Buttons.delete-page(i); }
                }
            }
            if Buttons.page-count < 5: addp := TouchArea {
                width: 60px;
                Text { text: "+ Page"; color: addp.has-hover ? Theme.accent-bright : Theme.accent; font-family: Theme.display-font; font-size: 15px; font-weight: 600; vertical-alignment: center; }
                clicked => { Buttons.add-page(); }
            }
            Rectangle { }
        }

        HorizontalLayout {
            spacing: 18px;
            // device preview — the stage fills the column; the device sits top-left in it
            VerticalLayout {
                horizontal-stretch: 1;
                spacing: 10px;
                preview-stage := Rectangle {
                    vertical-stretch: 1;
                    property <float> fit: min(1.0, min((self.width - 12px) / (DeviceCaps.side-w * 1px), (self.height - 12px) / (DeviceCaps.side-h * 1px)));
                    Rectangle {
                        width: DeviceCaps.side-w * 1px * parent.fit + 12px;
                        height: DeviceCaps.side-h * 1px * parent.fit + 12px;
                        x: 0;
                        y: 0;
                        background: #000000;
                        border-radius: 16px;
                        drop-shadow-blur: 16px;
                        drop-shadow-color: #000000;
                        DeviceScreen {
                            x: 6px; y: 6px;
                            width: parent.width - 12px;
                            height: parent.height - 12px;
                            mode: 1;
                            buttons: root.cur-page;
                            page-index: Buttons.page;
                            page-list: Buttons.page-list;
                            sel-tile: Buttons.sel;
                            tile-clicked(i) => { Buttons.sel = i; Buttons.select-tile(Buttons.page, i); }
                            page-clicked(i) => { Buttons.select-page(i); }
                        }
                    }
                }
                Text { text: "Side screen " + DeviceCaps.side-res + " · tap a tile to edit."; color: Theme.text3; font-size: 12px; }
            }

            // inspector (top-aligned)
            VerticalLayout {
                width: 344px;
                spacing: 14px;
                alignment: start;
                Card {
                    VerticalLayout {
                        padding: 16px;
                        spacing: 16px;
                        Text { text: "PAGE " + (Buttons.page + 1) + " · TILE " + (Buttons.sel + 1); color: Theme.text3; font-family: Theme.display-font; font-size: 11px; letter-spacing: 1.4px; }
                        VerticalLayout {
                            spacing: 7px;
                            SectionLabel { text: "LABEL"; }
                            Rectangle {
                                height: 40px;
                                background: Theme.panel2;
                                border-radius: 8px;
                                border-width: 1px;
                                border-color: ti.has-focus ? Theme.line2 : Theme.line;
                                ti := TextInput {
                                    x: 12px; width: parent.width - 24px;
                                    text: root.cur.label; color: Theme.text;
                                    font-family: Theme.body-font; font-size: 14px;
                                    vertical-alignment: center; single-line: true;
                                    selection-background-color: Theme.accent-dim;
                                    edited => { Buttons.set-label(self.text); }
                                }
                            }
                        }
                        VerticalLayout {
                            spacing: 7px;
                            SectionLabel { text: "TYPE"; }
                            Segmented { options: ["Push", "Toggle"]; index: root.cur.is-toggle ? 1 : 0; changed(i) => { Buttons.set-kind(i == 1); } }
                        }
                        VerticalLayout {
                            spacing: 8px;
                            SectionLabel { text: "ACTIVE COLOR"; }
                            HorizontalLayout {
                                spacing: 8px;
                                for c in root.palette: Swatch { tint: c; selected: root.cur.active-col == c; clicked => { Buttons.set-color(c); } }
                                Rectangle { }
                            }
                        }
                    }
                }
                if root.cur.is-toggle: Card {
                    VerticalLayout {
                        padding: 16px;
                        spacing: 10px;
                        HorizontalLayout {
                            VerticalLayout {
                                alignment: center;
                                spacing: 2px;
                                Text { text: "Sync state from game"; color: Theme.text; font-size: 14px; font-weight: 500; }
                                Text { text: "Mirror the sim instead of a local latch"; color: Theme.text3; font-size: 11px; }
                            }
                            Rectangle { }
                            VerticalLayout { alignment: center; ToggleSwitch { on: root.cur.sync-from-game; toggled(v) => { Buttons.set-sync(v); } } }
                        }
                        if root.cur.sync-from-game: VerticalLayout {
                            spacing: 5px;
                            SectionLabel { text: "GAME FIELD"; }
                            FieldDropdown {
                                value: root.cur.game-field;
                                options: Buttons.field-options;
                                picked(v) => { Buttons.set-field(v); }
                            }
                        }
                    }
                }
            }
        }
    }
}
