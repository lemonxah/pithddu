// Shift Lights — 12-LED RPM strip (HANDOFF.md §5).
import { Theme } from "../theme.slint";
import { AppState, Page, ShiftCfg, CarLib } from "../models.slint";
import { Card, PrimaryButton, Segmented, AppSlider, ToggleSwitch, Swatch, SectionLabel, Mono, GhostButton } from "../widgets.slint";

export component ShiftScreen inherits Rectangle {
    property <int> sel-led: 0;
    property <[color]> palette: [#00E676, #FFB300, #FF3B30, #2E9DFF, #D500F9];
    property <bool> blink: false;
    blink-timer := Timer {
        interval: max(60ms, 1s / (ShiftCfg.blink-hz * 2));
        running: ShiftCfg.blink-enabled;
        triggered => { blink = !blink; }
    }

    VerticalLayout {
        padding: 24px;
        spacing: 18px;
        // header
        HorizontalLayout {
            VerticalLayout {
                alignment: center;
                spacing: 3px;
                Text { text: "Shift Lights"; color: Theme.text; font-family: Theme.display-font; font-size: 24px; font-weight: 700; }
                Text { text: "12-LED RPM strip · per-gear thresholds & colours"; color: Theme.text3; font-size: 13px; }
            }
            Rectangle { }
            PrimaryButton { text: "SAVE TO DEVICE"; clicked => { ShiftCfg.save(); } }
        }

        HorizontalLayout {
            spacing: 18px;
            // ===== LEFT COLUMN =====
            VerticalLayout {
                horizontal-stretch: 1;
                spacing: 16px;
                // strip preview
                Card {
                    background: Theme.device;
                    height: 92px;
                    VerticalLayout {
                        padding: 18px;
                        HorizontalLayout {
                            spacing: 6px;
                            for l[i] in ShiftCfg.leds: Rectangle {
                                property <bool> redzone: l.threshold >= 90;
                                border-radius: 5px;
                                background: l.col;
                                opacity: redzone && ShiftCfg.blink-enabled && root.blink ? 0.18 : 1.0;
                                Rectangle {
                                    z: -1;
                                    width: parent.width + 14px;
                                    height: parent.height + 14px;
                                    x: -7px;
                                    y: -7px;
                                    border-radius: 12px;
                                    background: l.col.with-alpha(0.30);
                                }
                            }
                        }
                    }
                }
                // RPM axis — labels derived from the redline + first-LED point so
                // they always span the lit range (start..redline) and stay below it.
                HorizontalLayout {
                    padding-left: 4px;
                    padding-right: 4px;
                    // first-LED rpm and step, rounded to the nearest 100 for clean ticks.
                    property <int> startr: Math.round(ShiftCfg.redline-rpm * ShiftCfg.first-led-pct / 10000) * 100;
                    property <int> step: Math.round((ShiftCfg.redline-rpm - self.startr) / 300) * 100;
                    for tick in [
                        { v: "\{self.startr}", red: false }, { v: "\{self.startr + self.step}", red: false },
                        { v: "\{self.startr + 2 * self.step}", red: false }, { v: ShiftCfg.redline-rpm + " ▮", red: true } ]: Text {
                        text: tick.v;
                        color: tick.red ? Theme.red : Theme.text3;
                        font-family: Theme.mono-font;
                        font-size: 11px;
                        horizontal-alignment: tick.red ? right : left;
                        horizontal-stretch: 1;
                    }
                }
                // gear selector
                VerticalLayout {
                    spacing: 9px;
                    SectionLabel { text: "COLORS FOR GEAR"; }
                    HorizontalLayout {
                        spacing: 8px;
                        for g in [1, 2, 3, 4, 5, 6]: Rectangle {
                            width: 42px;
                            height: 38px;
                            border-radius: 8px;
                            background: g == ShiftCfg.sel-gear ? Theme.accent-dim : Theme.panel;
                            border-width: 1px;
                            border-color: g == ShiftCfg.sel-gear ? Theme.accent : Theme.line;
                            Text {
                                text: g;
                                color: g == ShiftCfg.sel-gear ? Theme.accent : Theme.text2;
                                font-family: Theme.display-font;
                                font-size: 16px;
                                font-weight: 700;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                            TouchArea { clicked => { ShiftCfg.sel-gear = g; ShiftCfg.select-gear(g); } }
                        }
                        Rectangle { }
                    }
                }
                // per-LED mapping grid
                VerticalLayout {
                    spacing: 9px;
                    SectionLabel { text: "PER-LED MAPPING — GEAR " + ShiftCfg.sel-gear; }
                    HorizontalLayout {
                        spacing: 6px;
                        for l[i] in ShiftCfg.leds: Rectangle {
                            height: 76px;
                            border-radius: 8px;
                            background: i == root.sel-led ? Theme.elev : Theme.panel;
                            border-width: 1px;
                            border-color: i == root.sel-led ? Theme.accent : Theme.line;
                            VerticalLayout {
                                padding: 7px;
                                spacing: 5px;
                                alignment: center;
                                Text {
                                    text: (i + 1 < 10 ? "0" : "") + (i + 1);
                                    color: Theme.text3;
                                    font-family: Theme.mono-font;
                                    font-size: 10px;
                                    horizontal-alignment: center;
                                }
                                HorizontalLayout {
                                    alignment: center;
                                    Rectangle { width: 20px; height: 20px; border-radius: 5px; background: l.col; }
                                }
                                Text {
                                    text: l.threshold + "%";
                                    color: Theme.text2;
                                    font-family: Theme.mono-font;
                                    font-size: 11px;
                                    horizontal-alignment: center;
                                }
                            }
                            TouchArea { clicked => { root.sel-led = i; } }
                        }
                    }
                    // selected-LED editor
                    Card {
                        height: 92px;
                        VerticalLayout {
                            padding: 14px;
                            spacing: 9px;
                            HorizontalLayout {
                                spacing: 10px;
                                Text { text: "LED " + (root.sel-led + 1); color: Theme.text; font-family: Theme.display-font; font-size: 14px; font-weight: 600; vertical-alignment: center; }
                                Rectangle { }
                                for c in root.palette: Swatch {
                                    tint: c;
                                    selected: ShiftCfg.leds[root.sel-led].col == c;
                                    clicked => { ShiftCfg.set-led-color(root.sel-led, c); }
                                }
                            }
                            HorizontalLayout {
                                spacing: 12px;
                                Text { text: "THRESHOLD"; color: Theme.text3; font-family: Theme.display-font; font-size: 11px; letter-spacing: 1px; vertical-alignment: center; width: 84px; }
                                AppSlider {
                                    value: ShiftCfg.leds[root.sel-led].threshold;
                                    minimum: 0;
                                    maximum: 100;
                                    changed(v) => { ShiftCfg.set-led-threshold(root.sel-led, Math.round(v)); }
                                }
                                Mono { text: ShiftCfg.leds[root.sel-led].threshold + "%"; font-size: 13px; width: 44px; }
                            }
                        }
                    }
                }
            }

            // ===== RIGHT COLUMN: SETTINGS =====
            VerticalLayout {
                width: 330px;
                spacing: 14px;
                Card {
                    VerticalLayout {
                        padding: 16px;
                        spacing: 16px;
                        SectionLabel { text: "RPM SOURCE"; }
                        Segmented {
                            options: ["From Car Library", "Custom"];
                            index: ShiftCfg.rpm-source;
                            changed(i) => { ShiftCfg.rpm-source = i; ShiftCfg.persist(); }
                        }
                        if ShiftCfg.rpm-source == 0: Rectangle {
                            height: 44px;
                            background: Theme.accent-dim;
                            border-radius: 8px;
                            border-width: 1px;
                            border-color: Theme.accent;
                            HorizontalLayout {
                                padding-left: 12px;
                                padding-right: 12px;
                                spacing: 8px;
                                alignment: center;
                                VerticalLayout {
                                    alignment: center;
                                    spacing: 1px;
                                    Text { text: ShiftCfg.car-name; color: Theme.accent-soft; font-size: 12px; }
                                    Mono { text: ShiftCfg.car-game + " · " + ShiftCfg.redline-rpm + " rpm"; color: Theme.accent; font-size: 11px; }
                                }
                                Rectangle { }
                                VerticalLayout {
                                    alignment: center;
                                    GhostButton { text: "Change →"; clicked => { AppState.page = Page.cars; } }
                                }
                            }
                        }
                        // redline
                        VerticalLayout {
                            spacing: 7px;
                            HorizontalLayout {
                                SectionLabel { text: "REDLINE RPM"; }
                                Rectangle { }
                                if ShiftCfg.rpm-source == 0: Rectangle {
                                    width: 64px;
                                    height: 18px;
                                    background: Theme.elev;
                                    border-radius: 5px;
                                    Text { text: "FROM CAR"; color: Theme.text3; font-family: Theme.display-font; font-size: 9px; letter-spacing: 1px; horizontal-alignment: center; vertical-alignment: center; }
                                }
                            }
                            Rectangle {
                                height: 38px;
                                background: Theme.panel2;
                                border-radius: 8px;
                                border-width: 1px;
                                border-color: Theme.line;
                                Mono {
                                    text: ShiftCfg.redline-rpm;
                                    color: ShiftCfg.rpm-source == 0 ? Theme.text3 : Theme.text;
                                    font-size: 16px;
                                    x: 12px;
                                    vertical-alignment: center;
                                }
                            }
                        }
                        // first led at
                        VerticalLayout {
                            spacing: 8px;
                            HorizontalLayout {
                                SectionLabel { text: "FIRST LED AT"; }
                                Rectangle { }
                                Mono { text: ShiftCfg.first-led-pct + "%"; font-size: 12px; }
                            }
                            AppSlider {
                                value: ShiftCfg.first-led-pct;
                                changed(v) => { ShiftCfg.first-led-pct = Math.round(v); ShiftCfg.persist(); }
                            }
                        }
                    }
                }
                // blink card
                Card {
                    VerticalLayout {
                        padding: 16px;
                        spacing: 12px;
                        HorizontalLayout {
                            SectionLabel { text: "BLINK AT REDLINE"; }
                            Rectangle { }
                            ToggleSwitch { on: ShiftCfg.blink-enabled; toggled(v) => { ShiftCfg.blink-enabled = v; ShiftCfg.persist(); } }
                        }
                        HorizontalLayout {
                            SectionLabel { text: "BLINK RATE"; }
                            Rectangle { }
                            Mono { text: ShiftCfg.blink-hz + " Hz"; font-size: 12px; }
                        }
                        AppSlider {
                            value: ShiftCfg.blink-hz;
                            minimum: 1;
                            maximum: 12;
                            changed(v) => { ShiftCfg.blink-hz = Math.round(v); ShiftCfg.persist(); }
                        }
                    }
                }
                // animation + brightness
                Card {
                    VerticalLayout {
                        padding: 16px;
                        spacing: 14px;
                        SectionLabel { text: "FILL ANIMATION"; }
                        Segmented {
                            options: ["L → R", "Center", "Edges"];
                            index: ShiftCfg.animation;
                            changed(i) => { ShiftCfg.animation = i; ShiftCfg.persist(); }
                        }
                        HorizontalLayout {
                            SectionLabel { text: "BRIGHTNESS"; }
                            Rectangle { }
                            Mono { text: ShiftCfg.brightness + "%"; font-size: 12px; }
                        }
                        AppSlider {
                            value: ShiftCfg.brightness;
                            changed(v) => { ShiftCfg.brightness = Math.round(v); ShiftCfg.persist(); }
                        }
                    }
                }
                Rectangle { }
            }
        }
    }
}
