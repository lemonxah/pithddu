// Car Library — lovely-car-data search (HANDOFF.md §6).
import { Theme } from "../theme.slint";
import { AppState, Page, CarLib, ShiftCfg, CarRow } from "../models.slint";
import { Card, PrimaryButton, GhostButton, SectionLabel, Mono, Dot } from "../widgets.slint";

export component CarsScreen inherits Rectangle {
    property <CarRow> sel: CarLib.sel >= 0 ? CarLib.results[CarLib.sel] : { name: "", make: "", redline: 0 };

    VerticalLayout {
        padding: 24px;
        spacing: 14px;
        // header
        HorizontalLayout {
            VerticalLayout {
                alignment: center;
                spacing: 3px;
                Text { text: "Car Library"; color: Theme.text; font-family: Theme.display-font; font-size: 24px; font-weight: 700; }
                Text { text: "Search specs · powered by lovely-car-data"; color: Theme.text3; font-size: 13px; }
            }
            Rectangle { }
            // dataset status + one-shot full download of the whole library
            VerticalLayout {
                alignment: center;
                HorizontalLayout {
                    spacing: 12px;
                    alignment: end;
                    VerticalLayout {
                        alignment: center;
                        spacing: 1px;
                        Mono {
                            text: CarLib.have-db ? CarLib.db-info : (CarLib.total-cars + " cars · github");
                            color: Theme.text3; font-size: 12px; horizontal-alignment: right;
                        }
                        if CarLib.status != "": Mono {
                            text: CarLib.status;
                            color: CarLib.downloading ? Theme.accent : Theme.text3;
                            font-size: 10px; horizontal-alignment: right;
                        }
                    }
                    VerticalLayout {
                        alignment: center;
                        GhostButton {
                            text: CarLib.downloading ? "Downloading…" : (CarLib.have-db ? "↻ Update library" : "↓ Download library");
                            active: CarLib.downloading;
                            clicked => { if (!CarLib.downloading) { CarLib.refresh(); } }
                        }
                    }
                }
            }
        }
        // game selector
        HorizontalLayout {
            spacing: 8px;
            VerticalLayout { alignment: center; SectionLabel { text: "GAME"; } }
            Flickable {
                horizontal-stretch: 1;
                height: 32px;
                viewport-height: 32px;
                HorizontalLayout {
                    spacing: 8px;
                    for g[i] in CarLib.games: GhostButton {
                        text: g;
                        active: i == CarLib.game;
                        clicked => { CarLib.select-game(i); }
                    }
                }
            }
            VerticalLayout { alignment: center; Text { text: "specs for " + CarLib.games[CarLib.game]; color: Theme.text3; font-size: 12px; } }
        }
        // search bar
        Rectangle {
            height: 44px;
            background: Theme.panel;
            border-radius: 9px;
            border-width: 1px;
            border-color: si.has-focus ? Theme.line2 : Theme.line;
            HorizontalLayout {
                padding-left: 14px;
                padding-right: 14px;
                spacing: 10px;
                Text { text: "⌕"; color: Theme.text3; font-size: 18px; vertical-alignment: center; }
                si := TextInput {
                    text: CarLib.query;
                    color: Theme.text;
                    font-family: Theme.body-font;
                    font-size: 14px;
                    vertical-alignment: center;
                    single-line: true;
                    horizontal-stretch: 1;
                    selection-background-color: Theme.accent-dim;
                    edited => { CarLib.set-query(self.text); }
                }
                if CarLib.loading: Text { text: "…"; color: Theme.accent; font-size: 16px; vertical-alignment: center; }
                Mono { text: CarLib.results.length + " results"; color: Theme.text3; font-size: 12px; }
            }
        }
        // dataset download progress (whole library is one ~84KB archive)
        if CarLib.downloading: VerticalLayout {
            spacing: 4px;
            HorizontalLayout {
                Text { text: "Downloading car database…"; color: Theme.text3; font-size: 11px; }
                Rectangle { }
                Mono { text: Math.round(CarLib.download-progress * 100) + "%"; color: Theme.text3; font-size: 11px; }
            }
            Rectangle {
                height: 6px;
                background: Theme.panel2;
                border-radius: 3px;
                Rectangle {
                    x: 0; y: 0;
                    width: parent.width * CarLib.download-progress;
                    height: parent.height;
                    background: Theme.accent;
                    border-radius: 3px;
                }
            }
        }
        // class chips
        Flickable {
            height: 32px;
            viewport-height: 32px;
            HorizontalLayout {
                spacing: 8px;
                for c[i] in CarLib.classes: GhostButton {
                    text: c;
                    active: i == CarLib.klass;
                    clicked => { CarLib.select-class(i); }
                }
            }
        }

        HorizontalLayout {
            spacing: 18px;
            vertical-stretch: 1;   // absorb extra height so header/filters stay pinned at the top
            // results list
            VerticalLayout {
                horizontal-stretch: 1;
                Card {
                    vertical-stretch: 1;   // fill the column height; rows stay pinned at the top
                    Flickable {
                        VerticalLayout {
                            alignment: start;   // pin rows to the top when there are only a few
                            padding: 8px;
                            spacing: 6px;
                            for r[i] in CarLib.results: Rectangle {
                                height: 58px;
                                background: r.active ? Theme.accent-dim : (i == CarLib.sel ? Theme.elev : Theme.panel2);
                                border-radius: 8px;
                                border-width: 1px;
                                border-color: r.active ? Theme.accent : (i == CarLib.sel ? Theme.line2 : transparent);
                                HorizontalLayout {
                                    padding-left: 12px;
                                    padding-right: 14px;
                                    spacing: 12px;
                                    // badge (vertically centered in the row)
                                    VerticalLayout {
                                        alignment: center;
                                        Rectangle {
                                            width: 40px;
                                            height: 40px;
                                            background: Theme.bg;
                                            border-radius: 8px;
                                            Mono { text: r.badge; color: Theme.text2; font-size: 13px; horizontal-alignment: center; vertical-alignment: center; }
                                        }
                                    }
                                    VerticalLayout {
                                        alignment: center;
                                        spacing: 2px;
                                        HorizontalLayout {
                                            spacing: 8px;
                                            Text { text: r.name; color: Theme.text; font-family: Theme.display-font; font-size: 15px; font-weight: 600; }
                                            if r.active: VerticalLayout { alignment: center; Rectangle {
                                                width: 50px; height: 16px; background: Theme.accent; border-radius: 4px;
                                                Text { text: "ACTIVE"; color: Theme.accent-text; font-family: Theme.display-font; font-size: 9px; letter-spacing: 1px; horizontal-alignment: center; vertical-alignment: center; }
                                            } }
                                        }
                                        Text { text: r.make + " · " + r.klass; color: Theme.text3; font-size: 12px; }
                                    }
                                    Rectangle { }
                                    VerticalLayout {
                                        alignment: center;
                                        spacing: 2px;
                                        Mono { text: r.power; color: Theme.text2; font-size: 12px; horizontal-alignment: right; }
                                        Mono { text: r.redline + " rpm"; color: Theme.accent-soft; font-size: 12px; horizontal-alignment: right; }
                                    }
                                }
                                TouchArea { clicked => { CarLib.select-car(i); } }
                            }
                            if CarLib.results.length == 0: Rectangle {
                                height: 80px;
                                Text { text: CarLib.loading ? "Loading…" : "No cars match"; color: Theme.text3; font-size: 13px; horizontal-alignment: center; vertical-alignment: center; }
                            }
                        }
                    }
                }
            }
            // detail panel
            VerticalLayout {
                width: 340px;
                spacing: 14px;
                Card {
                    VerticalLayout {
                        padding: 16px;
                        spacing: 14px;
                        // image placeholder
                        Rectangle {
                            height: 120px;
                            background: @linear-gradient(135deg, #16191e 0%, #101216 100%);
                            border-radius: 10px;
                            Text { text: CarLib.sel >= 0 ? root.sel.badge : "—"; color: Theme.text3; font-family: Theme.display-font; font-size: 34px; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; }
                        }
                        Text { text: CarLib.sel >= 0 ? root.sel.name : "Select a car"; color: Theme.text; font-family: Theme.display-font; font-size: 19px; font-weight: 700; }
                        Text { text: CarLib.sel >= 0 ? root.sel.make + " · " + root.sel.klass : ""; color: Theme.text3; font-size: 12px; }
                        // spec grid
                        HorizontalLayout {
                            spacing: 10px;
                            VerticalLayout {
                                spacing: 3px;
                                horizontal-stretch: 1;
                                Text { text: "POWER"; color: Theme.text3; font-family: Theme.display-font; font-size: 10px; letter-spacing: 1px; }
                                Mono { text: root.sel.power; color: Theme.text; font-size: 14px; }
                            }
                            VerticalLayout {
                                spacing: 3px;
                                horizontal-stretch: 1;
                                Text { text: "REDLINE"; color: Theme.accent; font-family: Theme.display-font; font-size: 10px; letter-spacing: 1px; }
                                Mono { text: root.sel.redline + " rpm"; color: Theme.accent; font-size: 14px; }
                            }
                        }
                        // shift-light colour preview (from lovely-car-data, before selecting)
                        if CarLib.sel >= 0: VerticalLayout {
                            spacing: 5px;
                            Text { text: "SHIFT LIGHTS"; color: Theme.text3; font-family: Theme.display-font; font-size: 10px; letter-spacing: 1px; }
                            HorizontalLayout {
                                spacing: 3px;
                                height: 14px;
                                if root.sel.leds.length == 0: Text { text: "no LED data"; color: Theme.text3; font-size: 11px; vertical-alignment: center; }
                                for c in root.sel.leds: Rectangle { background: c; border-radius: 3px; horizontal-stretch: 1; }
                            }
                        }
                        Rectangle { }
                        PrimaryButton {
                            text: "SET AS ACTIVE CAR";
                            enabled: CarLib.sel >= 0;
                            clicked => { CarLib.set-active(CarLib.sel); }
                        }
                        GhostButton {
                            text: "Apply " + root.sel.redline + " rpm → Shift Lights";
                            clicked => { CarLib.apply-redline(CarLib.sel); AppState.page = Page.shift; }
                        }
                    }
                }
                Rectangle { }
            }
        }
    }
}
