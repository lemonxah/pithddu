// Reusable styled primitives (HANDOFF.md §1 shape & spacing).
import { Theme } from "theme.slint";

// Uppercase tracked section label.
export component SectionLabel inherits Text {
    color: Theme.text3;
    font-family: Theme.display-font;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1.4px;
    // text is set by caller; uppercase by convention
}

export component Card inherits Rectangle {
    background: Theme.panel;
    border-radius: Theme.radius-card;
    border-width: 1px;
    border-color: Theme.line;
}

// Data number — JetBrains Mono.
export component Mono inherits Text {
    font-family: Theme.mono-font;
    color: Theme.text;
}

export component PrimaryButton inherits Rectangle {
    in property <string> text;
    in property <bool> enabled: true;
    callback clicked;
    height: 38px;
    min-width: 120px;
    background: !enabled ? Theme.panel2 : ta.pressed ? #00C98D : Theme.accent;
    border-radius: Theme.radius-input;
    animate background { duration: 90ms; }
    HorizontalLayout {
        alignment: center;
        padding-left: 18px;
        padding-right: 18px;
        Text {
            text: root.text;
            color: root.enabled ? Theme.accent-text : Theme.text3;
            font-family: Theme.display-font;
            font-size: 13px;
            font-weight: 700;
            letter-spacing: 1px;
            vertical-alignment: center;
        }
    }
    ta := TouchArea { enabled: root.enabled; clicked => { root.clicked(); } }
}

export component GhostButton inherits Rectangle {
    in property <string> text;
    in property <bool> active: false;
    callback clicked;
    height: 32px;
    background: active ? Theme.accent-dim : Theme.panel;
    border-radius: Theme.radius-input;
    border-width: 1px;
    border-color: active ? Theme.accent : Theme.line;
    HorizontalLayout {
        alignment: center;
        padding-left: 14px;
        padding-right: 14px;
        Text {
            text: root.text;
            color: active ? Theme.accent : Theme.text2;
            font-family: Theme.body-font;
            font-size: 13px;
            font-weight: 500;
            vertical-alignment: center;
        }
    }
    ta := TouchArea { clicked => { root.clicked(); } }
}

// Pill toggle (30-34x17-18px).
export component ToggleSwitch inherits Rectangle {
    // `on` is a pure input bound to the parent's source of truth. The switch must
    // NOT assign it directly — that replaces the binding and freezes the widget so
    // it stops following the bound value (e.g. when you select a different button
    // tile). It only emits `toggled`; the parent updates the source, which flows
    // back through the binding.
    in property <bool> on: false;
    callback toggled(bool);
    width: 34px;
    height: 18px;
    border-radius: 9px;
    background: on ? Theme.accent : #2A2E35;
    animate background { duration: 120ms; }
    knob := Rectangle {
        width: 14px;
        height: 14px;
        border-radius: 7px;
        y: 2px;
        x: root.on ? parent.width - self.width - 2px : 2px;
        background: root.on ? Theme.accent-text : #7A8088;
        animate x { duration: 120ms; easing: ease-out; }
    }
    TouchArea {
        clicked => { root.toggled(!root.on); }
    }
}

// 4px track, accent fill, glowing knob.
export component AppSlider inherits Rectangle {
    in property <float> minimum: 0;
    in property <float> maximum: 100;
    in-out property <float> value: 0;
    callback changed(float);
    height: 18px;
    function set-from-x(mx: length) {
        root.value = Math.clamp(root.minimum + (mx / root.width) * (root.maximum - root.minimum),
                                root.minimum, root.maximum);
        root.changed(root.value);
    }
    Rectangle {  // track
        y: parent.height / 2 - 2px;
        height: 4px;
        width: 100%;
        background: #000000;
        border-radius: 2px;
    }
    fill := Rectangle {
        x: 0;
        y: parent.height / 2 - 2px;
        height: 4px;
        width: parent.width * (root.value - root.minimum) / (root.maximum - root.minimum);
        background: Theme.accent;
        border-radius: 2px;
    }
    Rectangle {  // knob glow
        x: fill.width - self.width / 2;
        y: parent.height / 2 - self.height / 2;
        width: 22px;
        height: 22px;
        border-radius: 11px;
        background: Theme.accent-dim;
    }
    Rectangle {  // knob
        x: fill.width - self.width / 2;
        y: parent.height / 2 - self.height / 2;
        width: 15px;
        height: 15px;
        border-radius: 8px;
        background: Theme.accent;
    }
    ta := TouchArea {
        moved => { if (self.pressed) { root.set-from-x(self.mouse-x); } }
        clicked => { root.set-from-x(self.mouse-x); }
    }
}

export component Segmented inherits Rectangle {
    in property <[string]> options;
    // Pure input bound to the parent's source. The control must not assign `index`
    // itself — that severs the binding and freezes it (so it stops following e.g.
    // the selected button tile). It only emits `changed`; the parent updates the
    // source, which flows back through the binding.
    in property <int> index: 0;
    callback changed(int);
    height: 34px;
    background: Theme.panel;
    border-radius: Theme.radius-input;
    border-width: 1px;
    border-color: Theme.line;
    HorizontalLayout {
        padding: 3px;
        spacing: 3px;
        for opt[i] in root.options: Rectangle {
            background: i == root.index ? Theme.accent-dim : transparent;
            border-radius: 6px;
            border-width: 1px;
            border-color: i == root.index ? Theme.accent : transparent;
            Text {
                text: opt;
                color: i == root.index ? Theme.accent : Theme.text2;
                font-family: Theme.body-font;
                font-size: 12px;
                font-weight: 500;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
            TouchArea { clicked => { root.changed(i); } }
        }
    }
}

// Small rounded colour swatch.
export component Swatch inherits Rectangle {
    in property <color> tint;
    in property <bool> selected: false;
    callback clicked;
    width: 22px;
    height: 22px;
    border-radius: 6px;
    background: root.tint;
    border-width: selected ? 2px : 1px;
    border-color: selected ? Theme.text : Theme.line2;
    TouchArea { clicked => { root.clicked(); } }
}

// Live status dot.
export component Dot inherits Rectangle {
    in property <color> tint: Theme.green;
    width: 7px;
    height: 7px;
    border-radius: 4px;
    background: tint;
}
